- content_for :title, t("rva.cars.meta.index.page-title")
- meta :title, t("rva.cars.meta.index.title")
- meta :description, t("rva.cars.meta.index.description")

%h2
  = title_with_season(t('rva.cars.title'))

- if user_is_admin?
  = link_to t("rva.cars.new-car"), new_car_path(:season => selected_season&.id), :class => "btn mb-3"

= render :partial => "application/subnav", :locals => {:season => selected_season, :rankings => selected_season&.rankings}

#cars
  .row
    .col-xl-4.col-lg-6.col-md-12.col-sm-12.col-12
      .car-category-thumbnail.text-center
        %a{href: cars_rookie_path(:season => selected_season&.id) }
          .car-category-thumbnail-overlay
            = image_tag "cars/rookie.jpg", :alt => "", :class => "img-fluid car-category-img"
          .car-category-caption
            %p
              = category_name(SYS::CATEGORY::ROOKIE)
