- content_for :title, t("rva.cars.meta.classes.semi-pro.page-title")
- meta :title, t("rva.cars.meta.classes.semi-pro.title", org: ORG::NAME_SHORT)
- meta :description, t("rva.cars.meta.classes.semi-pro.description")
- meta :image, "https://rva.lat/assets/img/og/semi-pro.png"

#car-cards-display
  %h2
    = "#{title_with_season(t('rva.cars.title'))} - #{t("classes.semi-pro")}"

  = render :partial => "application/subnav", :locals => {:season => selected_season, :rankings => selected_season&.rankings, :category => SYS::CATEGORY::SEMI_PRO}

  = render "application/active_toggle"

  .sticky-top.search-bar
    .row
      .col-xl-11.col-lg-10.col-md-10.col-xs-9.col-8.sticky-top
        %input#input.form-control{placeholder: t("misc.placeholder.search"), type: "text"}/
      .col-xl-1.col-lg-2.col-md-2.col-xs-3.col-4
        = render :partial => "car_category_selector"

  - if @cars.none?
    %h5.text-center
      = t("rva.cars.shared.no-cars")
  - else
    .row
      - @cars.each do |car|
        = render :partial => "car_card", :locals => { :car => car }
